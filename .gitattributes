# Normalize line endings so the repo behaves identically from Windows, WSL, and Linux.
# All text files are stored with LF in the repository and checked out with LF.
* text=auto eol=lf

# Files that must keep Windows CRLF endings
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files - never touch line endings
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.jar binary
*.zip binary
